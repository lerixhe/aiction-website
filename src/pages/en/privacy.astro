---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/utils';
import { getEntry, render } from 'astro:content';

const lang = 'en';
const t = useTranslations(lang);

const entry = await getEntry('privacy', 'en');
if (!entry) throw new Error('Missing privacy policy entry for en');
const { Content } = await render(entry);
---

<Base
  title={t('privacy.title')}
  description={t('privacy.description')}
  lang={lang}
>
  <Header />
  <main class="container privacy-page">
    <article class="privacy-content">
      <Content />
    </article>
  </main>
  <Footer />
</Base>

<style>
  .privacy-page {
    padding-top: 3rem;
    padding-bottom: 4rem;
    max-width: 800px;
  }

  .privacy-content {
    line-height: 1.8;
  }

  .privacy-content :global(h1) {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .privacy-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-text);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .privacy-content :global(h3) {
    font-size: 1.2rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .privacy-content :global(p) {
    margin-bottom: 1rem;
    color: var(--color-text-secondary);
  }

  .privacy-content :global(strong) {
    color: var(--color-text);
  }

  .privacy-content :global(ul),
  .privacy-content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    color: var(--color-text-secondary);
  }

  .privacy-content :global(li) {
    margin-bottom: 0.25rem;
  }

  .privacy-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .privacy-content :global(th),
  .privacy-content :global(td) {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .privacy-content :global(th) {
    background: var(--color-bg-secondary);
    font-weight: 600;
    color: var(--color-text);
  }

  .privacy-content :global(td) {
    color: var(--color-text-secondary);
  }

  .privacy-content :global(code) {
    font-size: 0.85em;
  }

  .privacy-content :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .privacy-content :global(a:hover) {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }

  .privacy-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .privacy-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    margin-bottom: 1rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }
</style>
