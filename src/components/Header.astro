---
import { getLangFromUrl, useTranslations, getLocalePath } from '../i18n/utils';
import { languages } from '../i18n/ui';
import LanguagePicker from './LanguagePicker.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navItems = [
  { href: getLocalePath(lang), label: t('nav.home') },
  { href: getLocalePath(lang, 'docs'), label: t('nav.docs') },
  { href: getLocalePath(lang, 'changelog'), label: t('nav.changelog') },
];
---

<header class="header">
  <div class="header-inner container">
    <a href={getLocalePath(lang)} class="logo">
      <img src="/favicon.svg" alt="AIction" width="24" height="24" />
      <span>AIction</span>
    </a>

    <nav class="nav">
      {navItems.map((item) => (
        <a href={item.href} class="nav-link">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="header-right">
      <LanguagePicker />
      <a href="https://chromewebstore.google.com/detail/YOUR_EXTENSION_ID" class="cta-button">
        {t('nav.download')}
      </a>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    height: var(--header-height);
    display: flex;
    align-items: center;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .logo:hover {
    color: var(--color-text);
  }

  .logo img {
    border-radius: 4px;
  }

  .nav {
    display: flex;
    gap: 1.5rem;
  }

  .nav-link {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    background: var(--color-accent);
    color: white;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    transition: background 0.2s ease;
  }

  .cta-button:hover {
    background: var(--color-accent-hover);
    color: white;
  }

  @media (max-width: 768px) {
    .nav {
      display: none;
    }

    .cta-button {
      display: none;
    }
  }
</style>
