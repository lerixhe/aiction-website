---
import { getLangFromUrl, useTranslations, getLocalePath } from '../i18n/utils';
import { languages } from '../i18n/ui';
import LanguagePicker from './LanguagePicker.astro';
import ThemeToggle from './ThemeToggle.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navItems = [
  { href: getLocalePath(lang), label: t('nav.home') },
  { href: getLocalePath(lang, 'docs'), label: t('nav.docs') },
  { href: getLocalePath(lang, 'changelog'), label: t('nav.changelog') },
];
---

<header class="header">
  <div class="header-inner container">
    <a href={getLocalePath(lang)} class="logo">
      <img src="/favicon.svg" alt="AIction" width="24" height="24" />
      <span>AIction</span>
    </a>

    <nav class="nav">
      {navItems.map((item) => (
        <a href={item.href} class="nav-link">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="header-right">
      <ThemeToggle />
      <LanguagePicker />
      <a href="https://chromewebstore.google.com/detail/YOUR_EXTENSION_ID" class="cta-button">
        {t('nav.download')}
      </a>
      <button class="mobile-menu-toggle" aria-label={t('nav.toggle_menu')} aria-expanded="false">
        <span class="hamburger"></span>
      </button>
    </div>
  </div>

  <div class="mobile-nav">
    {navItems.map((item) => (
      <a href={item.href} class="mobile-nav-link">
        {item.label}
      </a>
    ))}
    <a href="https://chromewebstore.google.com/detail/YOUR_EXTENSION_ID" class="mobile-cta-button">
      {t('nav.download')}
    </a>
  </div>
</header>

<script>
  const toggle = document.querySelector('.mobile-menu-toggle');
  const mobileNav = document.querySelector('.mobile-nav');

  if (toggle && mobileNav) {
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', (!isOpen).toString());
      mobileNav.classList.toggle('is-open');
      document.body.classList.toggle('nav-open');
    });
  }
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(var(--color-bg-rgb), 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    height: var(--header-height);
    display: flex;
    align-items: center;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .logo:hover {
    color: var(--color-text);
  }

  .logo img {
    border-radius: 4px;
  }

  .nav {
    display: flex;
    gap: 1.5rem;
  }

  .nav-link {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    background: var(--color-accent);
    color: white;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    transition: background 0.2s ease;
  }

  .cta-button:hover {
    background: var(--color-accent-hover);
    color: white;
  }

  .mobile-menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 101;
  }

  .hamburger {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--color-text-secondary);
    position: relative;
    transition: background 0.2s ease;
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--color-text-secondary);
    transition: transform 0.2s ease;
  }

  .hamburger::before {
    top: -6px;
  }

  .hamburger::after {
    top: 6px;
  }

  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 1rem;
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  .mobile-nav-link {
    padding: 0.75rem 0;
    color: var(--color-text-secondary);
    font-size: 1rem;
    font-weight: 500;
    border-bottom: 1px solid var(--color-border);
    transition: color 0.2s ease;
  }

  .mobile-nav-link:hover {
    color: var(--color-text);
  }

  .mobile-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1rem;
    padding: 0.75rem 1rem;
    background: var(--color-accent);
    color: white;
    border-radius: 6px;
    font-size: 1rem;
    font-weight: 500;
    transition: background 0.2s ease;
  }

  .mobile-cta-button:hover {
    background: var(--color-accent-hover);
    color: white;
  }

  :global(body.nav-open) {
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .nav {
      display: none;
    }

    .cta-button {
      display: none;
    }

    .header-right {
      gap: 0.5rem;
    }

    .mobile-menu-toggle {
      display: block;
    }

    .mobile-menu-toggle[aria-expanded="true"] .hamburger {
      background: transparent;
    }

    .mobile-menu-toggle[aria-expanded="true"] .hamburger::before {
      transform: rotate(45deg);
      top: 0;
    }

    .mobile-menu-toggle[aria-expanded="true"] .hamburger::after {
      transform: rotate(-45deg);
      top: 0;
    }

    .mobile-nav.is-open {
      display: flex;
      position: absolute;
      top: var(--header-height);
      left: 0;
      right: 0;
      bottom: 0;
      min-height: calc(100vh - var(--header-height));
      z-index: 99;
      padding: 1.5rem;
    }
  }
</style>
