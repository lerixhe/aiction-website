---
import { getLangFromUrl, getLocalePath } from '../i18n/utils';
import { languages, type Lang } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

// Get the path without the locale prefix, preserving trailing slash
function getPathWithoutLocale(path: string): string {
  const hasTrailingSlash = path.endsWith('/') && path.length > 1;
  const parts = path.split('/').filter(Boolean);
  if (parts.length > 0 && parts[0] in languages) {
    const base = '/' + parts.slice(1).join('/');
    return hasTrailingSlash && !base.endsWith('/') ? base + '/' : base;
  }
  return path;
}

const basePath = getPathWithoutLocale(currentPath);
---

<div class="lang-picker" data-lang-picker>
  <button
    type="button"
    class="lang-trigger"
    aria-haspopup="menu"
    aria-expanded="false"
    aria-label={`Change language — current: ${languages[lang]}`}
    data-lang-trigger
  >
    <svg
      class="lang-globe"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <path d="M2 12h20"></path>
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
    </svg>
    <span class="lang-code">{lang.toUpperCase()}</span>
    <svg
      class="lang-chevron"
      width="10"
      height="10"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </button>

  <ul class="lang-menu" role="menu" data-lang-menu>
    {Object.entries(languages).map(([code, name]) => (
      <li role="none">
        <a
          href={getLocalePath(code as Lang, basePath.replace(/^\/|\/$/g, ''))}
          role="menuitem"
          class={`lang-item ${code === lang ? 'is-current' : ''}`}
          aria-current={code === lang ? 'page' : undefined}
          data-lang-key={code}
        >
          <span class="lang-native">{name}</span>
          {code === lang && (
            <svg
              class="lang-check"
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          )}
        </a>
      </li>
    ))}
  </ul>
</div>

<script>
  // Dropdown open/close
  const picker = document.querySelector('[data-lang-picker]');
  if (picker) {
    const trigger = picker.querySelector('[data-lang-trigger]');
    const menu = picker.querySelector('[data-lang-menu]');

    if (trigger && menu) {
      function setOpen(open: boolean) {
        if (open) {
          picker?.setAttribute('data-open', '');
          trigger?.setAttribute('aria-expanded', 'true');
        } else {
          picker?.removeAttribute('data-open');
          trigger?.setAttribute('aria-expanded', 'false');
        }
      }

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = picker?.hasAttribute('data-open');
        setOpen(!isOpen);
      });

      document.addEventListener('click', (e) => {
        if (!picker?.contains(e.target as Node)) {
          setOpen(false);
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && picker?.hasAttribute('data-open')) {
          setOpen(false);
          (trigger as HTMLElement)?.focus();
        }
      });
    }
  }
</script>

<style>
  .lang-picker {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .lang-trigger {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 8px;
    border-radius: 6px;
    background: transparent;
    border: 1px solid transparent;
    color: var(--color-text-secondary);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    transition: color 0.16s ease, background 0.16s ease, border-color 0.16s ease;
  }

  .lang-trigger:hover,
  .lang-trigger:focus-visible,
  .lang-picker[data-open] .lang-trigger {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.1);
    outline: none;
  }

  .lang-globe {
    flex: 0 0 auto;
    opacity: 0.7;
  }

  .lang-code {
    display: inline-block;
    min-width: 18px;
    text-align: center;
    letter-spacing: 0.06em;
  }

  .lang-chevron {
    flex: 0 0 auto;
    opacity: 0.6;
    transition: transform 0.2s ease;
  }

  .lang-picker[data-open] .lang-chevron {
    transform: rotate(180deg);
  }

  .lang-menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 140px;
    margin: 0;
    padding: 4px;
    list-style: none;
    background: rgba(18, 18, 20, 0.98);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5), 0 2px 8px rgba(0, 0, 0, 0.3);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    opacity: 0;
    transform: translateY(-4px) scale(0.98);
      pointer-events: none;
    transition: opacity 0.15s ease, transform 0.15s ease;
    z-index: 1000;
  }

  .lang-picker[data-open] .lang-menu {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .lang-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 8px 10px;
    border-radius: 6px;
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.8125rem;
    letter-spacing: 0;
    line-height: 1.3;
    text-decoration: none;
    transition: color 0.12s ease, background 0.12s ease;
    white-space: nowrap;
  }

  .lang-item:hover {
    color: rgba(255, 255, 255, 0.98);
    background: rgba(255, 255, 255, 0.06);
  }

  .lang-item.is-current {
    color: white;
    background: rgba(255, 255, 255, 0.08);
    cursor: default;
  }

  .lang-item.is-current:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .lang-check {
    flex: 0 0 auto;
    opacity: 0.9;
  }

  @media (max-width: 480px) {
    .lang-trigger {
      padding: 5px 7px 5px 9px;
      font-size: 0.75rem;
    }

    .lang-menu {
      min-width: 120px;
    }
  }
</style>
