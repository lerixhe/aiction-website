---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const steps = [
  { number: 1, text: t('quickstart.step1') },
  { number: 2, text: t('quickstart.step2') },
  { number: 3, text: t('quickstart.step3') },
  { number: 4, text: t('quickstart.step4') },
];
---

<section class="quickstart" id="quickstart">
  <div class="container">
    <h2 class="section-title">{t('quickstart.title')}</h2>
    <div class="steps">
      {steps.map((step) => (
        <div class="step">
          <span class="step-number">{step.number}</span>
          <p class="step-text">{step.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .quickstart {
    padding: 5rem 0;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 3rem;
  }

  .steps {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .step {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    transition: all 0.2s ease;
  }

  .step:hover {
    border-color: rgba(var(--color-text-rgb), 0.1);
    transform: translateX(4px);
  }

  .step-number {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent);
    color: white;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .step-text {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .quickstart {
      padding: 3rem 0;
    }

    .section-title {
      font-size: 1.5rem;
      margin-bottom: 2rem;
    }
  }
</style>
